generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// MODULE: Auth & Core
// -----------------------------------------------------------------------------

model User {
  id            String      @id @default(uuid())
  name          String
  email         String      @unique
  password_hash String
  role          Role
  branch_id     String?
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt
  
  branch        Branch?     @relation(fields: [branch_id], references: [id])
  audit_logs    AuditLog[]
  stock_movements StockMovement[]
  expenses      Expense[]

  @@map("users")
}

model Branch {
  id            String            @id @default(uuid())
  name          String
  address       String?
  phone         String?
  logo_url      String?
  created_at    DateTime          @default(now())
  
  users         User[]
  patients      Patient[]
  frame_stocks  FrameStock[]
  lens_stocks   LensStock[]
  stock_movements StockMovement[]
  expenses      Expense[]
  stock_batches StockBatch[]

  @@map("branches")
}

// -----------------------------------------------------------------------------
// MODULE: Patients & Records
// -----------------------------------------------------------------------------

model Patient {
  id            String            @id @default(uuid())
  nik           String?           @unique
  name          String
  gender        Gender?
  birth_date    DateTime?
  phone         String?
  address       String?
  bpjs_number   String?           @unique
  branch_id     String
  created_at    DateTime          @default(now())
  updated_at    DateTime          @updatedAt
  
  branch        Branch            @relation(fields: [branch_id], references: [id])
  examinations  EyeExamination[]
  orders        Order[]
  reminders     Reminder[]
  bpjs_claims   BpjsClaim[]

  @@map("patients")
}

model EyeExamination {
  id               String               @id @default(uuid())
  patient_id       String
  doctor_name      String?
  exam_date        DateTime             @default(now())
  source           PrescriptionSource   @default(internal)
  notes            String?
  created_at       DateTime             @default(now())
  
  patient          Patient              @relation(fields: [patient_id], references: [id])
  prescriptions    Prescription[]

  @@map("eye_examinations")
}

model Prescription {
  id               String               @id @default(uuid())
  exam_id          String
  type             PrescriptionType
  pd               Float?
  created_at       DateTime             @default(now())
  
  examination      EyeExamination       @relation(fields: [exam_id], references: [id], onDelete: Cascade)
  details          PrescriptionDetail[]
  orders           Order[]
  bpjs_claims      BpjsClaim[]

  @@map("prescriptions")
}

model PrescriptionDetail {
  id              String          @id @default(uuid())
  prescription_id String
  eye             Eye
  sph             Float
  cyl             Float?
  axis            Int?
  add_power       Float?
  
  prescription    Prescription @relation(fields: [prescription_id], references: [id], onDelete: Cascade)

  @@map("prescription_details")
}

// -----------------------------------------------------------------------------
// MODULE: Inventory
// -----------------------------------------------------------------------------

model Frame {
  id             String       @id @default(uuid())
  brand          String
  model          String
  sku            String?
  color          String?
  price          Float
  purchase_price Float?
  stock          Int          @default(0) // Global stock or sum
  created_at     DateTime     @default(now())
  
  stocks         FrameStock[]
  order_items    OrderItem[]
  supplier       Supplier?    @relation(fields: [supplier_id], references: [id])
  supplier_id    String?
  stock_movements StockMovement[]
  batches        StockBatch[]

  @@map("frames")
}

model Supplier {
  id             String       @id @default(uuid())
  name           String
  contact_person String?
  phone          String?
  address        String?
  email          String?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt

  frames         Frame[]
  lenses         Lens[]

  @@map("suppliers")
}

model FrameStock {
  id         String   @id @default(uuid())
  frame_id   String
  branch_id  String
  quantity   Int      @default(0)
  min_stock  Int      @default(5)
  updated_at DateTime @updatedAt
  
  branch     Branch   @relation(fields: [branch_id], references: [id])
  frame      Frame    @relation(fields: [frame_id], references: [id])

  @@unique([frame_id, branch_id])
  @@map("frame_stocks")
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum MovementSource {
  SALE
  PURCHASE
  OPNAME
  RETURN
}

model StockMovement {
  id          String         @id @default(uuid())
  type        MovementType
  source      MovementSource
  quantity    Int
  
  frame_id    String?
  lens_id     String?
  branch_id   String
  user_id     String
  notes       String?
  created_at  DateTime       @default(now())

  frame       Frame?         @relation(fields: [frame_id], references: [id])
  lens        Lens?          @relation(fields: [lens_id], references: [id])
  branch      Branch         @relation(fields: [branch_id], references: [id])
  user        User           @relation(fields: [user_id], references: [id])

  @@map("stock_movements")
}

model StockBatch {
  id               String   @id @default(uuid())
  frame_id         String?
  lens_id          String?
  branch_id        String
  purchase_price   Float
  initial_quantity Int
  current_quantity Int
  arrival_date     DateTime @default(now())
  created_at       DateTime @default(now())
  
  frame            Frame?   @relation(fields: [frame_id], references: [id])
  lens             Lens?    @relation(fields: [lens_id], references: [id])
  branch           Branch   @relation(fields: [branch_id], references: [id])

  @@map("stock_batches")
}

model Lens {
  id             String           @id @default(uuid())
  brand          String
  type           PrescriptionType
  feature        LensFeature
  index          String?
  price          Float
  purchase_price Float?
  created_at     DateTime         @default(now())
  
  stocks         LensStock[]
  order_items    OrderItem[]
  supplier       Supplier?    @relation(fields: [supplier_id], references: [id])
  supplier_id    String?
  stock_movements StockMovement[]
  batches        StockBatch[]

  @@map("lenses")
}

model LensStock {
  id         String   @id @default(uuid())
  lens_id    String
  branch_id  String
  quantity   Int      @default(0)
  min_stock  Int      @default(5)
  updated_at DateTime @updatedAt
  
  branch     Branch   @relation(fields: [branch_id], references: [id])
  lens       Lens     @relation(fields: [lens_id], references: [id])

  @@unique([lens_id, branch_id])
  @@map("lens_stocks")
}

// -----------------------------------------------------------------------------
// MODULE: POS & Transactions
// -----------------------------------------------------------------------------

model Order {
  id              String           @id @default(uuid())
  patient_id      String
  prescription_id String?
  order_date      DateTime         @default(now())
  status          OrderStatus      @default(pending)
  total_amount    Float            @default(0)
  discount        Float            @default(0)
  created_at      DateTime         @default(now())
  updated_at      DateTime         @default(now()) @updatedAt
  
  patient         Patient          @relation(fields: [patient_id], references: [id])
  prescription    Prescription?    @relation(fields: [prescription_id], references: [id])
  items           OrderItem[]
  payments        Payment[]
  invoices        Invoice[]
  bpjs_claim      BpjsClaim?

  @@map("orders")
}

model OrderItem {
  id           String      @id @default(uuid())
  order_id     String
  product_type ProductType
  frame_id     String?
  lens_id      String?
  price        Float
  cost_price   Float?      // HPP at time of sale (for FIFO accuracy)
  qty          Int
  
  order        Order       @relation(fields: [order_id], references: [id], onDelete: Cascade)
  frame        Frame?      @relation(fields: [frame_id], references: [id])
  lens         Lens?       @relation(fields: [lens_id], references: [id])

  @@map("order_items")
}

model Payment {
  id           String        @id @default(uuid())
  order_id     String
  method       PaymentMethod
  amount       Float
  paid_at      DateTime      @default(now())
  
  order        Order         @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Invoice {
  id             String   @id @default(uuid())
  invoice_number String   @unique
  order_id       String
  total_amount   Float
  dp_amount      Float    @default(0)
  remaining      Float
  created_at     DateTime @default(now())
  
  order          Order    @relation(fields: [order_id], references: [id])

  @@map("invoices")
}

// -----------------------------------------------------------------------------
// MODULE: BPJS
// -----------------------------------------------------------------------------

model BpjsClaim {
  id               String      @id @default(uuid())
  patient_id       String
  prescription_id  String
  order_id         String?     @unique
  claim_date       DateTime    @default(now())
  status           ClaimStatus @default(draft)
  rejection_reason String?
  created_at       DateTime    @default(now())
  
  patient          Patient     @relation(fields: [patient_id], references: [id])
  prescription     Prescription @relation(fields: [prescription_id], references: [id])
  order            Order?      @relation(fields: [order_id], references: [id])

  @@map("bpjs_claims")
}

// -----------------------------------------------------------------------------
// MODULE: Notifications & Reminders
// -----------------------------------------------------------------------------

model Reminder {
  id            String           @id @default(uuid())
  patient_id    String
  schedule_date DateTime
  type          ReminderType
  status        ReminderStatus   @default(pending)
  created_at    DateTime         @default(now())
  
  patient       Patient          @relation(fields: [patient_id], references: [id])

  @@map("reminders")
}

// -----------------------------------------------------------------------------
// MODULE: Expenses
// -----------------------------------------------------------------------------

model ExpenseCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  created_at  DateTime  @default(now())
  
  expenses    Expense[]

  @@map("expense_categories")
}

model Expense {
  id            String          @id @default(uuid())
  category_id   String
  branch_id     String
  user_id       String
  amount        Float
  notes         String?
  expense_date  DateTime        @default(now())
  created_at    DateTime        @default(now())
  
  category      ExpenseCategory @relation(fields: [category_id], references: [id])
  branch        Branch          @relation(fields: [branch_id], references: [id])
  user          User            @relation(fields: [user_id], references: [id])

  @@map("expenses")
}

// -----------------------------------------------------------------------------
// MODULE: Logs
// -----------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(uuid())
  user_id    String?
  action     String
  table_name String
  record_id  String
  old_data   Json?
  new_data   Json?
  created_at DateTime @default(now())
  
  user       User?    @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum Role {
  admin
  kasir
  optometris
  owner
}

enum Gender {
  male
  female
}

enum PrescriptionSource {
  rs
  internal
}

enum PrescriptionType {
  monofocal
  bifocal
  progressive
}

enum Eye {
  R
  L
}

enum LensFeature {
  normal
  bluecromic
  photochromic
  blue_protect
}

enum ProductType {
  frame
  lens
  service
}

enum OrderStatus {
  pending
  processed
  ready
  completed
  cancelled
}

enum PaymentMethod {
  cash
  debit
  credit
  transfer
  bpjs
}

enum ClaimStatus {
  draft
  submitted
  approved
  rejected
  paid
}

enum ReminderType {
  checkup
  pickup
  promo
}

enum ReminderStatus {
  pending
  sent
  failed
}
