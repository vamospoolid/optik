# Database Configuration
DATABASE_URL="postgresql://user:password@localhost:5432/optikpro?schema=public"

# Auth Configuration
JWT_ACCESS_SECRET="your_access_token_secret_here_replace_me"
JWT_REFRESH_SECRET="your_refresh_token_secret_here_replace_me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Security Configuration
ENCRYPTION_KEY="your_32_chars_encryption_key_here" # AES-256 requires 32 bytes
ENCRYPTION_IV="your_16_chars_iv_here"             # AES-256 requires 16 bytes

# Port
PORT=3001
